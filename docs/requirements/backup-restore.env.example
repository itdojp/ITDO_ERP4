# Backup/restore environment template.
# Copy this file outside the repository, chmod 600, and fill values through the
# approved secret delivery path. Never commit credentials or real target identifiers.

# Runtime context and immutable bundle metadata
ENVIRONMENT=prod
COMMIT_SHA=
DB_VERSION=
SCHEMA_VERSION=
APP_VERSION=
BACKUP_RETENTION_CLASS=daily
# hourly | daily | weekly | monthly

# Database connection
DB_HOST=
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres

# Local backup directory
BACKUP_DIR=./.codex-local/tmp/erp4-backups
BACKUP_PREFIX=erp4

# Optional asset directory (PDF/attachments)
ASSET_DIR=

# Client-side OpenPGP encryption.
# Sakura profile requires GPG_RECIPIENT and validates the encrypted packet before upload.
GPG_RECIPIENT=
GPG_HOME=
# Production recommendation after a verified upload: 1.
# Keep 0 during investigation/recovery so a failed copy does not remove plaintext.
GPG_REMOVE_PLAINTEXT=0

# Explicit S3-compatible provider profile
S3_PROVIDER=sakura
# aws | sakura
# Credential values do not belong in this file. Point AWS CLI at a separate,
# owner-only credential source or use approved process-level secret injection.
AWS_PROFILE=
AWS_SHARED_CREDENTIALS_FILE=
S3_ENDPOINT_URL=
S3_BUCKET=
S3_PREFIX=erp4/prod
S3_REGION=
# Set 1 to download the uploaded object and re-verify its manifest.
S3_VERIFY_DOWNLOAD=1

# Google Drive secondary copy. This never replaces the Sakura primary.
# Keep none until a dedicated backup OAuth principal and Shared Drive folder
# have passed the operator preflight. Do not reuse ERP4_GDRIVE_* credentials.
BACKUP_SECONDARY_PROVIDER=none
# none | gdrive
BACKUP_GDRIVE_CLIENT_ID=
BACKUP_GDRIVE_CLIENT_SECRET=
BACKUP_GDRIVE_REFRESH_TOKEN=
BACKUP_GDRIVE_SHARED_DRIVE_ID=
BACKUP_GDRIVE_FOLDER_ID=
BACKUP_GDRIVE_UPLOAD_TIMEOUT_SEC=300
BACKUP_GDRIVE_RETRY_MAX=3
# 1 performs a full ciphertext verification download after upload. Manifests
# are always downloaded and verified because they are small.
BACKUP_GDRIVE_VERIFY_DOWNLOAD=0
# Defaults to BACKUP_DIR/.gdrive-state. It contains Drive file IDs and must
# remain owner-only, outside committed evidence.
BACKUP_GDRIVE_STATE_DIR=
# Destructive commands remain disabled without both an explicit command and
# the corresponding confirmation. Do not enable during repo-side testing.
BACKUP_GDRIVE_TRASH_CONFIRM=0
BACKUP_GDRIVE_PRUNE_CONFIRM=0

# AWS-only server-side encryption / readiness settings.
# Sakura confidentiality must not depend on these values.
KMS_ENDPOINT_URL=
SSE_KMS_KEY_ID=
SSE_S3=
# aws:kms | AES256 | any
EXPECT_SSE=any

# Readiness mode. A fake run is repo-side evidence only and can never become a
# target-environment pass record.
S3_EXECUTION_MODE=fake
S3_REAL_RUN_CONFIRM=0
STRICT=1
CHECK_WRITE=0
# Sakura provider-console evidence file. Keep outside the repository, owner-only
# (mode 600), non-symlink, with:
# versioningStatus=...
# publicAccessStatus=...
# accessControlStatus=...
# retentionStatus=...
S3_OPERATOR_EVIDENCE_FILE=

# Recording helper options
RUN_CHECK=0
FAIL_ON_CHECK=0
DATE_STAMP=
RUN_LABEL=

# Retention policy. Time windows are fixed in code:
# hourly=48 hours, daily=30 days, weekly=12 weeks, monthly=13 months.
# The minimum generation counts are an operator decision and have no implicit default.
RETENTION_MIN_HOURLY=
RETENTION_MIN_DAILY=
RETENTION_MIN_WEEKLY=
RETENTION_MIN_MONTHLY=
RETENTION_NOW=
PLAN_JSON=
PLAN_MARKDOWN=
RESULT_JSON=
# Apply remains disabled unless all three values are supplied after private review.
PRUNE_CONFIRM=0
RETENTION_EXCLUSIVE_LOCK_CONFIRM=0
RETENTION_PLAN_SHA256=

# Optional remote-host copy retained for the legacy/transition profile
REMOTE_HOST=
REMOTE_USER=
REMOTE_PORT=22
REMOTE_DIR=
REMOTE_SSH_KEY=
REMOTE_SSH_OPTS=
REMOTE_KEEP_DAYS=

# Restore options. Do not set RESTORE_CONFIRM=1 without an isolated target DB and
# explicit human approval.
RESTORE_CONFIRM=0
SKIP_GLOBALS=1
# RESTORE_CLEAN is supported by scripts/podman-poc.sh (PoC) only.
RESTORE_CLEAN=0
BACKUP_FILE=
BACKUP_GLOBALS_FILE=
BACKUP_ASSETS_FILE=
