# Owner-only environment for erp4-storage-readiness.service.
# Never commit real credentials, provider identifiers, endpoints, or backup IDs.

# Backup manifest context and local source
ENVIRONMENT=prod
BACKUP_DIR=/home/REPLACE_ME/.local/share/erp4/db-backups
BACKUP_PREFIX=erp4

# Sakura primary profile. Keep blank until delivered through the approved private path.
S3_PROVIDER=
S3_ENDPOINT_URL=
S3_BUCKET=
S3_PREFIX=
S3_REGION=
AWS_PROFILE=
AWS_SHARED_CREDENTIALS_FILE=

# Google Drive secondary. These credentials are separate from application Drive.
BACKUP_SECONDARY_PROVIDER=none
BACKUP_GDRIVE_CLIENT_ID=
BACKUP_GDRIVE_CLIENT_SECRET=
BACKUP_GDRIVE_REFRESH_TOKEN=
BACKUP_GDRIVE_SHARED_DRIVE_ID=
BACKUP_GDRIVE_FOLDER_ID=
BACKUP_GDRIVE_UPLOAD_TIMEOUT_SEC=300
BACKUP_GDRIVE_RETRY_MAX=3
BACKUP_GDRIVE_STATE_DIR=

# Read-only monitoring thresholds fixed by Epic #1975 unless explicitly overridden.
STORAGE_READINESS_DRIVE_WARNING_PERCENT=70
STORAGE_READINESS_DRIVE_CRITICAL_PERCENT=80
STORAGE_READINESS_LOCAL_MAX_AGE_HOURS=2
STORAGE_READINESS_SAKURA_MAX_AGE_HOURS=2
STORAGE_READINESS_S3_TIMEOUT_MS=30000
STORAGE_READINESS_GDRIVE_MAX_AGE_HOURS=30
STORAGE_READINESS_RESTORE_MAX_AGE_DAYS=30
STORAGE_READINESS_MIN_HOURLY=48
STORAGE_READINESS_MIN_DAILY=30
STORAGE_READINESS_MIN_WEEKLY=12
STORAGE_READINESS_MIN_MONTHLY=13

# Private restore evidence input. Keep outside docs/ and chmod 600.
STORAGE_READINESS_RESTORE_EVIDENCE_FILE=
STORAGE_READINESS_RESTORE_EXPECTED_BACKUP_ID=
