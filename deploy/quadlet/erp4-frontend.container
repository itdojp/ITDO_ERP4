[Unit]
Description=ERP4 frontend container
Wants=network-online.target
After=network-online.target erp4-backend.service

[Container]
Image=localhost/erp4-frontend:REPLACE_WITH_COMMIT_SHA
Pull=never
ContainerName=erp4-frontend
Network=erp4.network

[Service]
Restart=always
TimeoutStartSec=120

[Install]
WantedBy=default.target
