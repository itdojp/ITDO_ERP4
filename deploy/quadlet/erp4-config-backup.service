[Unit]
Description=ERP4 Quadlet config backup

[Service]
Type=oneshot
EnvironmentFile=%h/.config/containers/systemd/erp4-maintenance.env
ExecStart=/usr/bin/bash -lc 'cd "$ERP4_REPO_DIR" && QUADLET_TARGET_DIR="${QUADLET_TARGET_DIR:-$HOME/.config/containers/systemd}" QUADLET_BACKUP_DIR="${QUADLET_BACKUP_DIR:-$HOME/.local/share/erp4/quadlet-backups}" ./scripts/quadlet/backup-and-check.sh --include-units ${ERP4_BACKUP_INCLUDE_PROXY:+--include-proxy}'
