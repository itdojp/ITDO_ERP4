{
  "name": "erp4-backend-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node scripts/run-tests.js",
    "test:ci": "node scripts/run-tests.js",
    "coverage": "npm run prisma:generate && tsc -p tsconfig.coverage.json && c8 --all --src src --report-dir coverage/full --temp-directory .nyc_output/full --reporter text-summary --reporter json-summary --reporter lcov node scripts/run-tests.js",
    "coverage:auth": "npm run prisma:generate && tsc -p tsconfig.coverage.json && c8 --all --src src --report-dir coverage/auth --temp-directory .nyc_output/auth --reporter text-summary --reporter json-summary --reporter lcov node scripts/run-tests.js test/authGatewayRoutes.test.js test/localLoginRoutes.test.js test/authAdminBffRoutes.test.js test/userIdentityRoutes.test.js test/localCredentialRoutes.test.js test/envValidation.test.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "prisma:generate": "prisma generate"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@sinclair/typebox": "^0.34.49",
    "@types/web-push": "^3.6.4",
    "argon2": "^0.44.0",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "googleapis": "^171.4.0",
    "iconv-lite": "^0.7.2",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "rate-limiter-flexible": "^10.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@fastify/swagger": "^9.7.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "c8": "^11.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "openapi-diff": "^0.24.1",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "@mrleebo/prisma-ast": "^0.14.0",
    "@hono/node-server": "^1.19.11",
    "diff": "^4.0.4",
    "fast-xml-parser": "^5.5.5",
    "flatted": "^3.4.1",
    "hono": "^4.12.7",
    "lodash": "^4.17.23",
    "minimatch": "^10.2.4",
    "qs": "^6.15.0",
    "effect": "^3.21.0"
  }
}
