{
  "name": "erp4-frontend-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview",
    "build:design-system": "node ./scripts/build-design-system.cjs",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "coverage:ui-core": "FRONTEND_COVERAGE_SCOPE=ui-core vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "lint": "eslint \"src/**/*.{ts,tsx,jsx,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,jsx,js,css,json,md}\"",
    "build:budget": "node ./scripts/check-build-budget.cjs"
  },
  "dependencies": {
    "@itdo/design-system": "^1.1.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "minimatch": "^10.2.4",
    "flatted": "^3.4.1"
  }
}
